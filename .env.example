# Copiar a .env.local y completar con tu proyecto Supabase:
# https://supabase.com/dashboard/project/_/settings/api
#
# Puede ser la clave JWT "anon" (empieza por eyJ...) o la clave publicable nueva (sb_publishable_...).

NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_publica_anon_o_publishable
